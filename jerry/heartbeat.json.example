{
  "rules": [
    {
      "id": "morning_briefing",
      "name": "Morning Briefing",
      "cron": "0 7 * * 1-5",
      "type": "briefing",
      "enabled": true,
      "config": {
        "sections": ["emails", "calendar", "sprint", "prs", "commits", "slack"]
      }
    },
    {
      "id": "comms_check",
      "name": "Hourly Comms Check",
      "cron": "0 9-17 * * 1-5",
      "type": "comms_check",
      "enabled": true,
      "config": {}
    },
    {
      "id": "eod_summary",
      "name": "End of Day Summary",
      "cron": "0 18 * * 1-5",
      "type": "eod_summary",
      "enabled": true,
      "config": {}
    }
  ]
}
