# === Discord (required) ===
# Create bot applications at https://discord.com/developers/applications
# Each bot needs: Message Content Intent enabled, same permissions as Jerry
# Bot → Reset Token → paste here

# Jerry — CEO / Personal Assistant (required)
DISCORD_BOT_TOKEN=
# Your Discord user ID (right-click your name → Copy User ID, enable Developer Mode in settings)
OWNER_DISCORD_ID=
# Discord server ID (right-click server name → Copy Server ID)
DISCORD_GUILD_ID=

# === Crew Bot Tokens (optional — add as you create them) ===
ACE_BOT_TOKEN=
SCOTT_BOT_TOKEN=
SAGE_BOT_TOKEN=
ATLAS_BOT_TOKEN=
NIX_BOT_TOKEN=

# === Linear (optional) ===
# Get your API key from: Settings → API → Personal API Keys
LINEAR_API_KEY=

# === Slack (optional) ===
# Create a Slack app, add bot scopes (channels:history, chat:write, etc.)
SLACK_BOT_TOKEN=

# === GitHub (optional) ===
# Default org/repo for PR reviews, commits, etc.
# Requires `gh` CLI authenticated: gh auth login
GITHUB_ORG=
GITHUB_REPO=

# === Google Workspace (optional, macOS only) ===
# Requires `gws` CLI: brew install gws && gws auth setup

# === Claude CLI (required) ===
# Install: npm install -g @anthropic-ai/claude-cli
# Auth: claude auth login
# Model override (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# === Jerry Config ===
# Timezone for cron scheduling
TZ=America/New_York
